# ===== POSTGRESQL =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dynamic_pricing
POSTGRES_USER=pricing_user
POSTGRES_PASSWORD=your_secure_password_here

# ===== QDRANT =====
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=product_embeddings

# ===== MINIO (simula S3) =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_minio_password_here
MINIO_BUCKET=pricing-artifacts

# ===== AIRFLOW =====
AIRFLOW_UID=50000
AIRFLOW_GID=50000
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__WEBSERVER__SECRET_KEY=your_webserver_secret_here
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# ===== MODELO NLP =====
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.85
SIMILARITY_REVIEW_THRESHOLD=0.70

# ===== PRICING ENGINE =====
MIN_MARGIN_PCT=0.10
MAX_DEMAND_ADJUSTMENT=0.10
MAX_STOCK_ADJUSTMENT=0.05
UNDERCUT_BUFFER=1.00
